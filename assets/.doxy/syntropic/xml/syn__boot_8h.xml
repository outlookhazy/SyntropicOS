        <type><ref refid="syn__defs_8h_1ac74d19fd322a889de9e46b79fb277c00" kindref="member">SYN_Status</ref></type>
        <definition>SYN_Status syn_boot_init</definition>
        <argsstring>(SYN_Boot *boot, SYN_ParamStore *store, uint16_t safe_threshold)</argsstring>
        <name>syn_boot_init</name>
        <param>
          <type><ref refid="structSYN__Boot" kindref="compound">SYN_Boot</ref> *</type>
