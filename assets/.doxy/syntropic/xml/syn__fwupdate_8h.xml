<parameternamelist>
<parametername>upd</parametername>
</parameternamelist>
<parameterdescription>
<para>Updater instance. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>slot_addr</parametername>
</parameternamelist>
<parameterdescription>
<para>Flash base address of the target slot. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>max_size</parametername>
</parameternamelist>
<parameterdescription>
<para>Maximum image size in bytes (excl. header). </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>page_buf</parametername>
</parameternamelist>
<parameterdescription>
<para>Caller-provided page buffer. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>page_buf_size</parametername>
</parameternamelist>
<parameterdescription>
<para>Buffer size (should match flash write granularity). </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>SYN_OK on success, SYN_ERROR on flash erase failure. </para>
</simplesect>
</para>
