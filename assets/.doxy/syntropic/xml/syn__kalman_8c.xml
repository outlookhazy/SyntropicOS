      <memberdef kind="function" id="syn__kalman_8c_1ad03ca93379c411cd33ca83fafa2376ca" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type><ref refid="syn__defs_8h_1ac74d19fd322a889de9e46b79fb277c00" kindref="member">SYN_Status</ref></type>
        <definition>SYN_Status syn_kalman_init</definition>
        <argsstring>(SYN_Kalman *kf, const SYN_Kalman_Config *cfg)</argsstring>
        <name>syn_kalman_init</name>
        <param>
          <type><ref refid="structSYN__Kalman" kindref="compound">SYN_Kalman</ref> *</type>
          <declname>kf</declname>
        </param>
        <param>
          <type>const <ref refid="structSYN__Kalman__Config" kindref="compound">SYN_Kalman_Config</ref> *</type>
          <declname>cfg</declname>
        </param>
        <briefdescription>
<para>Initialize the Kalman filter. </para>
        </briefdescription>
        <detaileddescription>
<para>The caller must have populated cfg-&gt;F, cfg-&gt;H, cfg-&gt;Q, cfg-&gt;R, and initial cfg-&gt;x and cfg-&gt;P before calling this. Scratch matrices must be assigned via SYN_KALMAN_SCRATCH_ASSIGN.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>kf</parametername>
</parameternamelist>
<parameterdescription>
<para>Kalman filter instance. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>cfg</parametername>
</parameternamelist>
<parameterdescription>
<para>Configuration (caller-owned, must outlive kf). </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>SYN_OK on success, SYN_INVALID_PARAM on dimension mismatch. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="src/syntropic/dsp/syn_kalman.c" line="20" column="12" bodyfile="src/syntropic/dsp/syn_kalman.c" bodystart="20" bodyend="39"/>
      </memberdef>
      <memberdef kind="function" id="syn__kalman_8c_1a1aafada7cee05b3098ebeb5da03c60dd" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void syn_kalman_predict</definition>
        <argsstring>(SYN_Kalman *kf)</argsstring>
        <name>syn_kalman_predict</name>
        <param>
          <type><ref refid="structSYN__Kalman" kindref="compound">SYN_Kalman</ref> *</type>
          <declname>kf</declname>
        </param>
        <briefdescription>
<para>Predict step: propagate state and covariance forward. </para>
        </briefdescription>
        <detaileddescription>
<para>After this call:<itemizedlist>
<listitem><para>x̂⁻ = F · x̂ (state predicted forward)</para>
</listitem><listitem><para>P⁻ = F · P · Fᵀ + Q (covariance grows)</para>
</listitem></itemizedlist>
</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>kf</parametername>
</parameternamelist>
<parameterdescription>
<para>Kalman filter instance. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
