        (kf)-&gt;temp_nm   = &amp;prefix##_nm;                         \
        (kf)-&gt;temp_mn   = &amp;prefix##_mn;                         \
        (kf)-&gt;temp_mm   = &amp;prefix##_mm;                         \
        (kf)-&gt;temp_mm_2 = &amp;prefix##_mm2;                        \
        (kf)-&gt;temp_n1   = &amp;prefix##_n1;                         \
        (kf)-&gt;temp_m1   = &amp;prefix##_m1;                         \
    } while (0)</initializer>
