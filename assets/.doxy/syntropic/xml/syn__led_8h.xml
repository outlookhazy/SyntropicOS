<codeline><highlight class="normal"><ref refid="syn__led_8c_1a9cfe968960b3294b5614880222684691" kindref="member">syn_led_blink</ref>(&amp;led,<sp/>500,<sp/>500);<sp/><sp/><sp/><sp/><sp/></highlight><highlight class="comment">//<sp/>500ms<sp/>on,<sp/>500ms<sp/>off</highlight><highlight class="normal"></highlight></codeline>
