    <innerclass refid="structSYN__MotorOutput" prot="public">SYN_MotorOutput</innerclass>
    <briefdescription>
<para>Abstract motor output interface. </para>
    </briefdescription>
    <detaileddescription>
<para>Decouples the motor controller from specific motor drivers. Any motor (DC, stepper, brushless, etc.) implements this three-function interface and can be driven by syn_motor_ctrl.</para>
<para><simplesect kind="par"><title>Usage</title><para><programlisting><codeline><highlight class="comment">//<sp/>DC<sp/>motor<sp/>—<sp/>use<sp/>the<sp/>factory:</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><ref refid="structSYN__MotorOutput" kindref="compound">SYN_MotorOutput</ref><sp/>out<sp/>=<sp/><ref refid="syn__dc__motor_8c_1a61cd420228e33bb64e73a5cad4f4a122" kindref="member">syn_dc_motor_output</ref>(&amp;my_dc);</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">//<sp/>Custom<sp/>motor<sp/>—<sp/>wire<sp/>directly:</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><ref refid="structSYN__MotorOutput" kindref="compound">SYN_MotorOutput</ref><sp/>out<sp/>=<sp/>{</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>.<ref refid="structSYN__MotorOutput_1aa4093e161107629b490bef6d083ebe99" kindref="member">set_output</ref><sp/>=<sp/>my_motor_set_output,</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>.coast<sp/><sp/><sp/><sp/><sp/><sp/>=<sp/>my_motor_coast,</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>.brake<sp/><sp/><sp/><sp/><sp/><sp/>=<sp/>my_motor_brake,</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>.ctx<sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>=<sp/>&amp;my_motor,</highlight></codeline>
<codeline><highlight class="normal">};</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">//<sp/>Pass<sp/>to<sp/>motor<sp/>controller:</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">cfg.motor<sp/>=<sp/>out;</highlight></codeline>
</programlisting> </para>
</simplesect>
</para>
