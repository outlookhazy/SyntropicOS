    <sectiondef kind="define">
      <memberdef kind="define" id="syn__pid_8h_1a5c2df664219d291524a8a8dc4ecad0e5" prot="public" static="no">
        <name>SYN_PID_GAINS</name>
        <param><defname>kp_f</defname></param>
        <param><defname>ki_f</defname></param>
        <param><defname>kd_f</defname></param>
        <param><defname>scale_val</defname></param>
        <param><defname>omin</defname></param>
        <param><defname>omax</defname></param>
        <initializer>    ((<ref refid="structSYN__PID__Config" kindref="compound">SYN_PID_Config</ref>){                                          \
        .kp    = (int32_t)((kp_f) * (scale_val)),               \
        .ki    = (int32_t)((ki_f) * (scale_val) * 1000),        \
        .kd    = (int32_t)((kd_f) * (scale_val)),               \
        .scale = (scale_val),                                   \
        .out_min = (omin),                                      \
        .out_max = (omax),                                      \
    })</initializer>
        <briefdescription>
<para>Convenience macro to create a PID config from human-readable gains. </para>
        </briefdescription>
        <detaileddescription>
<para>Accepts floating-point gain values and a scale factor. Computes the integer ki with the ×1000 factor built in, so you specify ki as a normal per-second integral gain.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>kp_f</parametername>
</parameternamelist>
<parameterdescription>
<para>Proportional gain (float). </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>ki_f</parametername>
</parameternamelist>
<parameterdescription>
<para>Integral gain per second (float). </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>kd_f</parametername>
</parameternamelist>
<parameterdescription>
<para>Derivative gain (float). </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>scale_val</parametername>
</parameternamelist>
<parameterdescription>
<para>Integer scale divisor (e.g., 256). </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>omin</parametername>
</parameternamelist>
<parameterdescription>
<para>Minimum output. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>omax</parametername>
</parameternamelist>
<parameterdescription>
<para>Maximum output. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><ref refid="structSYN__PID__Config" kindref="compound">SYN_PID_Config</ref> struct initializer.</para>
</simplesect>
<simplesect kind="par"><title>Example</title><para><programlisting><codeline><highlight class="normal">SYN_PID_Config<sp/>cfg<sp/>=<sp/>SYN_PID_GAINS(1.5,<sp/>0.5,<sp/>0.1,<sp/>256,<sp/>-1000,<sp/>1000);</highlight></codeline>
<codeline><highlight class="normal">//<sp/>kp<sp/>=<sp/>(int)(1.5<sp/>*<sp/>256)<sp/><sp/><sp/><sp/><sp/><sp/><sp/>=<sp/>384</highlight></codeline>
<codeline><highlight class="normal">//<sp/>ki<sp/>=<sp/>(int)(0.5<sp/>*<sp/>256<sp/>*<sp/>1000)<sp/>=<sp/>128000</highlight></codeline>
<codeline><highlight class="normal">//<sp/>kd<sp/>=<sp/>(int)(0.1<sp/>*<sp/>256)<sp/><sp/><sp/><sp/><sp/><sp/><sp/>=<sp/>25</highlight></codeline>
</programlisting> </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
