<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>.<ref refid="structSYN__DMA__Config_1ab71f28b4b4f1c543617167730a4ccff8" kindref="member">channel</ref><sp/><sp/><sp/>=<sp/>0,</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>.direction<sp/>=<sp/><ref refid="syn__port__dma_8h_1adc7958755cff8ac2eed2aea1513981e8a154967065913bd859c1a7461b9cc00ea" kindref="member">SYN_DMA_PERIPH_TO_MEM</ref>,</highlight></codeline>
