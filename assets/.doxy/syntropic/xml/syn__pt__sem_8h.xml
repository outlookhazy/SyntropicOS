      <memberdef kind="define" id="syn__pt__sem_8h_1ab64fa11539f8b6db675fde7e6d0b348a" prot="public" static="no">
        <name>PT_SEM_WAIT</name>
        <param><defname>pt</defname></param>
        <param><defname>sem</defname></param>
        <initializer>    do {                                                       \
        <ref refid="syn__pt_8h_1a0a7f29e2a1e2caaf5bcc343412eef273" kindref="member">PT_WAIT_UNTIL</ref>(pt, (sem)-&gt;count &gt; 0);                   \
        (sem)-&gt;count--;                                        \
    } while (0)</initializer>
        <briefdescription>
<para>Block the protothread until the semaphore count is &gt; 0, then decrement it. </para>
        </briefdescription>
        <detaileddescription>
<para>Must be called from within a protothread (between PT_BEGIN/PT_END).</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>pt</parametername>
</parameternamelist>
<parameterdescription>
<para>Protothread. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>sem</parametername>
</parameternamelist>
<parameterdescription>
<para>Semaphore to wait on. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
