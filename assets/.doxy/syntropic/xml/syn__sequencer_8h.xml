    <briefdescription>
<para>Timed action sequencer — choreograph steps with delays. </para>
    </briefdescription>
    <detaileddescription>
<para>Execute a sequence of actions with configurable delays between them. Non-blocking — call <computeroutput>update()</computeroutput> from your main loop.</para>
<para><simplesect kind="par"><title>Usage</title><para><programlisting><codeline><highlight class="keywordtype">void</highlight><highlight class="normal"><sp/>relay_on(</highlight><highlight class="keywordtype">void</highlight><highlight class="normal"><sp/>*ctx)<sp/>{<sp/><ref refid="syn__gpio_8h_1a1df83ba3f60dd521135c2885b89622df" kindref="member">syn_gpio_write</ref>(RELAY_PIN,<sp/>SYN_GPIO_HIGH);<sp/>}</highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keywordtype">void</highlight><highlight class="normal"><sp/>relay_off(</highlight><highlight class="keywordtype">void</highlight><highlight class="normal"><sp/>*ctx)<sp/>{<sp/><ref refid="syn__gpio_8h_1a1df83ba3f60dd521135c2885b89622df" kindref="member">syn_gpio_write</ref>(RELAY_PIN,<sp/>SYN_GPIO_LOW);<sp/>}</highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keywordtype">void</highlight><highlight class="normal"><sp/>read_sensor(</highlight><highlight class="keywordtype">void</highlight><highlight class="normal"><sp/>*ctx)<sp/>{<sp/>*(</highlight><highlight class="keywordtype">int</highlight><highlight class="normal">*)ctx<sp/>=<sp/>adc_read();<sp/>}</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keyword">static</highlight><highlight class="normal"><sp/></highlight><highlight class="keyword">const</highlight><highlight class="normal"><sp/><ref refid="structSYN__SeqStep" kindref="compound">SYN_SeqStep</ref><sp/>steps[]<sp/>=<sp/>{</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>{<sp/>relay_on,<sp/><sp/><sp/><sp/><sp/>NULL,<sp/><sp/>0<sp/>},<sp/><sp/><sp/><sp/><sp/><sp/></highlight><highlight class="comment">//<sp/>step<sp/>0:<sp/>relay<sp/>on,<sp/>no<sp/>delay</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>{<sp/>NULL,<sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>NULL,<sp/><sp/>200<sp/>},<sp/><sp/><sp/><sp/><sp/></highlight><highlight class="comment">//<sp/>step<sp/>1:<sp/>wait<sp/>200ms</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>{<sp/>read_sensor,<sp/><sp/>&amp;val,<sp/><sp/>0<sp/>},<sp/><sp/><sp/><sp/><sp/><sp/></highlight><highlight class="comment">//<sp/>step<sp/>2:<sp/>read<sp/>sensor</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>{<sp/>relay_off,<sp/><sp/><sp/><sp/>NULL,<sp/><sp/>100<sp/>},<sp/><sp/><sp/><sp/><sp/></highlight><highlight class="comment">//<sp/>step<sp/>3:<sp/>relay<sp/>off,<sp/>then<sp/>wait<sp/>100ms</highlight><highlight class="normal"></highlight></codeline>
