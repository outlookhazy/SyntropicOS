    <briefdescription>
<para>Hobby servo controller — pulse-width positioning. </para>
    </briefdescription>
    <detaileddescription>
<para>Standard hobby servos expect a 50 Hz PWM signal with a pulse width of 1000–2000 µs (center = 1500 µs). This module provides angle-based and microsecond-based positioning with optional smooth movement.</para>
<para>Requires a hardware timer or syn_soft_pwm for pulse generation. The module computes pulse width; you connect it to your PWM output.</para>
<para><simplesect kind="par"><title>Usage</title><para><programlisting><codeline><highlight class="normal"><ref refid="structSYN__Servo" kindref="compound">SYN_Servo</ref><sp/>servo;</highlight></codeline>
<codeline><highlight class="normal"><ref refid="syn__servo_8c_1a7b5a0b87c87a43747650a016dce7f32e" kindref="member">syn_servo_init</ref>(&amp;servo,<sp/>1000,<sp/>2000,<sp/>180);<sp/></highlight><highlight class="comment">//<sp/>1000–2000µs,<sp/>180°<sp/>range</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><ref refid="syn__servo_8c_1ad6906c43c4b5dd8b074e48e9bbc25a78" kindref="member">syn_servo_set_angle</ref>(&amp;servo,<sp/>90);<sp/><sp/><sp/></highlight><highlight class="comment">//<sp/>center</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">uint16_t<sp/>pw<sp/>=<sp/><ref refid="syn__servo_8h_1a9f67dcb75919ba346d63a487437271ac" kindref="member">syn_servo_get_pulse_us</ref>(&amp;servo);<sp/><sp/></highlight><highlight class="comment">//<sp/>→<sp/>1500µs</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">//<sp/>Smooth<sp/>move:</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><ref refid="syn__servo_8c_1a5c9bde3fa6510c2a24d45ee884489467" kindref="member">syn_servo_move_to</ref>(&amp;servo,<sp/>0,<sp/>500);<sp/><sp/></highlight><highlight class="comment">//<sp/>move<sp/>to<sp/>0°<sp/>over<sp/>500ms</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keywordflow">while</highlight><highlight class="normal"><sp/>(!<ref refid="syn__servo_8h_1a177b30b5415ee9973cdc7f3872486ea1" kindref="member">syn_servo_at_target</ref>(&amp;servo))<sp/>{</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><ref refid="syn__servo_8c_1a4383e2c73727f4360e086d12690b376d" kindref="member">syn_servo_update</ref>(&amp;servo);<sp/><sp/><sp/><sp/><sp/><sp/><sp/></highlight><highlight class="comment">//<sp/>call<sp/>periodically</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>set_pwm_us(<ref refid="syn__servo_8h_1a9f67dcb75919ba346d63a487437271ac" kindref="member">syn_servo_get_pulse_us</ref>(&amp;servo));</highlight></codeline>
<codeline><highlight class="normal">}</highlight></codeline>
</programlisting> </para>
</simplesect>
</para>
