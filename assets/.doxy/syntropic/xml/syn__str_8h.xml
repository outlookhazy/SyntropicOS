        <type>size_t</type>
        <definition>size_t syn_str_split</definition>
        <argsstring>(char *str, char delimiter, char *tokens[], size_t max_tokens)</argsstring>
        <name>syn_str_split</name>
        <param>
          <type>char *</type>
          <declname>str</declname>
        </param>
        <param>
