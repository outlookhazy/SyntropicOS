<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><ref refid="syn__trace_8h_1a4b1193d9aeee964b5a38a61b670d13d7" kindref="member">SYN_TRACE</ref>(&amp;trace,<sp/>EVT_ISR_ENTER,<sp/>irq_num);</highlight></codeline>
<codeline><highlight class="normal"><ref refid="syn__trace_8h_1a4b1193d9aeee964b5a38a61b670d13d7" kindref="member">SYN_TRACE</ref>(&amp;trace,<sp/>EVT_TASK_SWITCH,<sp/>task_id);</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">//<sp/>Dump<sp/>from<sp/>CLI<sp/>or<sp/>debugger:</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><ref refid="syn__trace_8c_1a5d6ef52f60e6716d99d35842cc3a621b" kindref="member">syn_trace_dump</ref>(&amp;trace,<sp/>print_func);</highlight></codeline>
</programlisting> </para>
</simplesect>
</para>
